      "timeoutInMillisecond": 30000,
      "paginationType": "NONE",
      "encodeParamsToggle": true,
      "body": "\nCREATE OR REPLACE FUNCTION public.fn_order_bevestigd_voorraad()\nRETURNS trigger LANGUAGE plpgsql SECURITY DEFINER AS $$\nDECLARE al_geboekt integer;\nBEGIN\n    IF NEW.status <> 'bevestigd' OR OLD.status = 'bevestigd' THEN RETURN NEW; END IF;\n    SELECT COUNT(*) INTO al_geboekt FROM public.voorraad_mutaties\n    WHERE order_id = NEW.id AND type = 'uit';\n    IF al_geboekt > 0 THEN RETURN NEW; END IF;\n    INSERT INTO public.voorraad_mutaties (product_id, order_id, type, aantal, opmerking, createdby)\n    SELECT r.product_id, NEW.id, 'uit'::public.voorraad_mutatie_type, -r.aantal,\n           'Automatisch afgeboekt bij bevestiging order #' || NEW.volgnummer,\n           COALESCE(NEW.modifiedby, NEW.createdby)\n    FROM public.order_regels r\n    WHERE r.order_id = NEW.id AND r.deletedon IS NULL;\n    RETURN NEW;\nEND; $$\n",
      "pluginSpecifiedTemplates": [
        {
          "value": true
        }
      ]
    },
