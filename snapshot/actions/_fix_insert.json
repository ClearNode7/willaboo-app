                                                          "timeoutInMillisecond":  15000,
                                                          "paginationType":  "NONE",
                                                          "encodeParamsToggle":  true,
                                                          "body":  "\nCREATE OR REPLACE FUNCTION public.fn_orderregel_insert_voorraad()\nRETURNS trigger LANGUAGE plpgsql SECURITY DEFINER AS $$\nDECLARE v_volgnummer integer;\nBEGIN\n    SELECT volgnummer INTO v_volgnummer FROM public.orders\n    WHERE id = NEW.order_id AND status = \u0027bevestigd\u0027;\n    IF v_volgnummer IS NULL THEN RETURN NEW; END IF;\n    INSERT INTO public.voorraad_mutaties\n        (product_id, order_id, type, aantal, opmerking, createdby)\n    VALUES (NEW.product_id, NEW.order_id,\n            \u0027uit\u0027::public.voorraad_mutatie_type, -NEW.aantal,\n            \u0027Automatisch afgeboekt bij toevoeging aan bevestigde order #\u0027 || v_volgnummer,\n            COALESCE(NEW.createdby, \u002700000000-0000-0000-0000-000000000001\u0027::uuid));\n    RETURN NEW;\nEND; $$\n",
                                                          "pluginSpecifiedTemplates":  [
                                                                                           {
                                                                                               "value":  true
                                                                                           }
                                                                                       ]
                                                      },
