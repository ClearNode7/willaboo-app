    "actionConfiguration": {
      "timeoutInMillisecond": 15000,
      "paginationType": "NONE",
      "encodeParamsToggle": true,
      "body": "\nCREATE OR REPLACE FUNCTION public.fn_orderregel_insert_voorraad()\nRETURNS trigger LANGUAGE plpgsql SECURITY DEFINER AS $$\nDECLARE v_volgnummer integer;\nBEGIN\n    SELECT volgnummer INTO v_volgnummer FROM public.orders\n    WHERE id = NEW.order_id AND status = 'bevestigd';\n    IF v_volgnummer IS NULL THEN RETURN NEW; END IF;\n    INSERT INTO public.voorraad_mutaties\n        (product_id, order_id, type, aantal, opmerking, createdby)\n    VALUES (NEW.product_id, NEW.order_id,\n            'uit'::public.voorraad_mutatie_type, -NEW.aantal,\n            'Automatisch afgeboekt bij toevoeging aan bevestigde order #' || v_volgnummer,\n            COALESCE(NEW.createdby, '00000000-0000-0000-0000-000000000001'::uuid));\n    RETURN NEW;\nEND; $$\n",
      "pluginSpecifiedTemplates": [
        {
          "value": true
        }
      ]
    },
