      "encodeParamsToggle": true,
      "body": "SELECT \n  v.product_id,\n  v.product_naam,\n  v.eenheid,\n  v.huidige_voorraad,\n  COALESCE(p.min_voorraad, 10) AS min_voorraad\nFROM voorraad_per_product_view v\nJOIN producten p ON p.id = v.product_id\nWHERE p.deletedon IS NULL\nORDER BY v.product_naam ASC"
