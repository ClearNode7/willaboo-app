                                                          "encodeParamsToggle":  true,
                                                          "body":  "\nCREATE OR REPLACE FUNCTION public.fn_orderregel_update_voorraad()\nRETURNS trigger LANGUAGE plpgsql SECURITY DEFINER AS $$\nDECLARE v_volgnummer integer;\nBEGIN\n    SELECT volgnummer INTO v_volgnummer FROM public.orders\n    WHERE id = NEW.order_id AND status = \u0027bevestigd\u0027;\n    IF v_volgnummer IS NULL THEN RETURN NEW; END IF;\n    IF OLD.deletedon IS NULL AND NEW.deletedon IS NOT NULL THEN\n        INSERT INTO public.voorraad_mutaties (product_id, order_id, type, aantal, opmerking, createdby)\n        VALUES (NEW.product_id, NEW.order_id, \u0027in\u0027::public.voorraad_mutatie_type, NEW.aantal,\n                \u0027Automatisch teruggeBoekt bij verwijdering uit bevestigde order #\u0027 || v_volgnummer,\n                NEW.modifiedby);\n        RETURN NEW;\n    END IF;\n    IF OLD.deletedon IS NOT NULL AND NEW.deletedon IS NULL THEN\n        INSERT INTO public.voorraad_mutaties (product_id, order_id, type, aantal, opmerking, createdby)\n        VALUES (NEW.product_id, NEW.order_id, \u0027uit\u0027::public.voorraad_mutatie_type, -NEW.aantal,\n                \u0027Automatisch afgeboekt bij herstel van bevestigde order #\u0027 || v_volgnummer,\n                NEW.modifiedby);\n        RETURN NEW;\n    END IF;\n    IF NEW.deletedon IS NULL AND NEW.aantal \u003c\u003e OLD.aantal THEN\n        INSERT INTO public.voorraad_mutaties (product_id, order_id, type, aantal, opmerking, createdby)\n        VALUES (NEW.product_id, NEW.order_id, \u0027correctie\u0027::public.voorraad_mutatie_type,\n                -(NEW.aantal - OLD.aantal),\n                \u0027Correctie bij aantalwijziging op bevestigde order #\u0027 || v_volgnummer\n                || \u0027 (\u0027 || OLD.aantal || \u0027 ÔåÆ \u0027 || NEW.aantal || \u0027)\u0027,\n                NEW.modifiedby);\n        RETURN NEW;\n    END IF;\n    RETURN NEW;\nEND; $$\n",
