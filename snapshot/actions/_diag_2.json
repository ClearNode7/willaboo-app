      "paginationType": "NONE",
      "encodeParamsToggle": true,
      "body": "\nSELECT r.deletedon, r.aantal, p.naam as product, o.volgnummer, o.status\nFROM order_regels r\nJOIN producten p ON p.id = r.product_id\nJOIN orders o ON o.id = r.order_id\nWHERE r.deletedon IS NOT NULL\nORDER BY r.deletedon DESC\nLIMIT 5\n",
