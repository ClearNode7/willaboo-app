                                                          "body":  "INSERT INTO public.klanten (\n  klant_type, status,\n  bedrijfsnaam, kvk, btwnummer,\n  aanhef, titulatuur, initialen,\n  voornaam, tussenvoegsel, achternaam,\n  email, telefoon,\n  geslacht, createdby\n) VALUES (\n  CAST({{SelectKlantType.selectedOptionValue}} AS public.klant_type),\n  CAST({{SelectStatus.selectedOptionValue}} AS public.klant_status),\n  NULLIF({{InputpBedrijfsnaam.text}}, \u0027\u0027),\n  NULLIF({{InputKvk.text}}, \u0027\u0027),\n  NULLIF({{InputBtwnummer.text}}, \u0027\u0027),\n  CAST(NULLIF({{SelectAanhef.selectedOptionValue}}, \u0027\u0027) AS public.aanhef),\n  CAST(NULLIF({{SelectTitulatuur.selectedOptionValue}}, \u0027\u0027) AS public.titulatuur),\n  NULLIF({{InputInitialen.text}}, \u0027\u0027),\n  NULLIF({{InputVoornaam.text}}, \u0027\u0027),\n  NULLIF({{InputTussenvoegsel.text}}, \u0027\u0027),\n  NULLIF({{InputAchternaam.text}}, \u0027\u0027),\n  NULLIF({{InputEmail.text}}, \u0027\u0027),\n  NULLIF({{InputTelefoon.text}}, \u0027\u0027),\n  CASE {{SelectAanhef.selectedOptionValue}}\n    WHEN \u0027Dhr.\u0027 THEN \u0027man\u0027::public.geslacht\n    WHEN \u0027Mw.\u0027  THEN \u0027vrouw\u0027::public.geslacht\n    ELSE             \u0027anders\u0027::public.geslacht\n  END,\n  public.profile_id_by_email({{appsmith.user.email}})\n)\nRETURNING id;",
