    "actionConfiguration": {
      "timeoutInMillisecond": 15000,
      "paginationType": "NONE",
      "encodeParamsToggle": true,
      "body": "\nINSERT INTO public.voorraad_mutaties (product_id, order_id, type, aantal, opmerking, createdby)\nSELECT \n    r.product_id,\n    r.order_id,\n    'in'::public.voorraad_mutatie_type,\n    r.aantal,\n    'Handmatige correctie: terugboeken verwijderde regel (Bombs ×3, order #151)',\n    r.modifiedby\nFROM order_regels r\nJOIN producten p ON p.id = r.product_id\nJOIN orders o ON o.id = r.order_id\nWHERE lower(p.naam) LIKE '%bomb%'\n  AND o.volgnummer = 151\n  AND r.deletedon IS NOT NULL\n  AND r.deletedon::date = '2026-05-14'\n  AND NOT EXISTS (\n    SELECT 1 FROM voorraad_mutaties vm\n    WHERE vm.order_id = r.order_id\n      AND vm.product_id = r.product_id\n      AND vm.opmerking LIKE '%Handmatige correctie%'\n  )\n",
      "pluginSpecifiedTemplates": [
        {
          "value": true
        }
      ]
    },
    "runBehaviour": "MANUAL",
